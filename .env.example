# Your citizenship (ISO country code, e.g. IR, US, DE, TR)
CITIZENSHIP=IR

# Do you currently hold a Schengen visa? (true/false)
HAS_SCHENGEN_VISA=false

# Home airport IATA code (e.g. IKA, IST, DXB)
HOME_AIRPORT=IST

# How many days ahead to search for flights (default 60)
SEARCH_DAYS_AHEAD=60

# Number of travelers
TRAVELERS=1

# Maximum total budget per person in USD (flights + hotel)
MAX_PRICE_USD=500
